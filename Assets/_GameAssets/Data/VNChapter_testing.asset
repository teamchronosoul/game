        emotion: 0
        crossfadeSeconds: 0.2
    - rid: 4444056912327082061
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_003
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: You're standing in the middle of the mystery forest, mustering up your
          courage. You're about to become a student at ChronoSoul, the legendary
          Magical Academy!
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082062
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_004
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "The wondrous creature in front of you speaks again, glowing with warm
          light. \n"
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082063
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_005
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: My name's Lumis. And I am here to ensure your test runs smoothly!
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082064
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_006
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Do you have any questions before we start?
        addToLog: 1
        nextStepId: step_007
    - rid: 4444056912327082065
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_007
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: "Tell me what's going to happen, step by step. \n"
          nextStepId: step_009
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Whatever comes up today, I'm ready.
          nextStepId: step_009
          kind: 0
          premiumPrice: 0
          effects:
          - type: 0
            key: 
            boolValue: 0
            intValue: 0
            stringValue: 
    - rid: 4444056912327082067
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_009
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: 'I got you. You''re going to meet a mentor from each of the 4 faculties
          of the Magical Academy. Each mentor will ask you three questions. By the
          end of the test, you''ll know which faculty you''re in! '
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082068
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_010
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Oh, look! Here's the first mentor!
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082069
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_011
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: A tall, pale man with a piercing, cold gaze appears before you.
        addToLog: 1
        nextStepId: step_012
    - rid: 4444056912327082070
      type: {class: VNCommandStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_012
        label: 
        disableSkip: 0
        stopAuto: 0
        command:
          rid: 4444056912327082072
        nextStepId: step_013
    - rid: 4444056912327082072
      type: {class: VNShowCharacterCommand, ns: VN, asm: Assembly-CSharp}
      data:
        characterId: Shinrai
        slot: 0
        pose: 0
        emotion: 0
        crossfadeSeconds: 0.2
    - rid: 4444056912327082073
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_013
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Good day to you. I am Shinrai, Dean of the Order of Labyrinth. And
          I DO NOT enjoy small talk, so let us get straight to the point. '
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035779
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_014
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: What is your work routine like?
        addToLog: 1
        nextStepId: step_015
    - rid: 4444056937922035780
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_015
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: I prefer to have a schedule with clear deadlines.
          nextStepId: step_016
          kind: 0
          premiumPrice: 0
          effects: []
        - text: I like to work when I feel inspired
          nextStepId: step_016
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035782
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_016
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: I see. I have to warn you. Studying at the Academy is no easy endeavor.
          You must be prepared to apply your brilliant mind whenever it is required.
          So let us see how you reason.
        addToLog: 1
        nextStepId: step_017
    - rid: 4444056937922035784
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_017
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: How do you approach ordinary things?
        addToLog: 1
        nextStepId: step_018
    - rid: 4444056937922035785
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_018
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Relying on regular tried-and-true methods
          nextStepId: step_019
          kind: 0
          premiumPrice: 0
          effects: []
        - text: I like to do them my own way
          nextStepId: step_019
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035786
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_019
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: ' Is that so?'
        addToLog: 1
        nextStepId: step_020
    - rid: 4444056937922035787
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_020
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: There is a hint of interest in Shinrai's intense gaze.
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035788
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_021
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Well, let us proceed to a truly intriguing question. Lumis, please
          assist. '
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035789
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_022
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Gladly!
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035790
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_023
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "Shinrai raises his hand, conjuring a small sphere in his palm. Lumis
          then shines a ray of light on the sphere and a tiny eye appears within
          it. \n"
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035791
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_024
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: 'This is the eye of the Labyrinth. It sees one''s true intentions. '
        addToLog: 1
        nextStepId: step_025
    - rid: 4444056937922035792
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_025
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: Now tell me. Is it worse...
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035797
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 96d5e482f9c4414f99abc97c0b076fa5
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: To be unjust.
          nextStepId: 1ffbc8265e3a4613be4e7beb20875167
          kind: 0
          premiumPrice: 0
          effects: []
        - text: To have no mercy for others.
          nextStepId: 1ffbc8265e3a4613be4e7beb20875167
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035798
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 1ffbc8265e3a4613be4e7beb20875167
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'The eye in Shinrai''s palm blinks and shrinks itself until it''s no
          longer there. Shinrai nods at you politely.

'
        addToLog: 1
        nextStepId: 14135ef00796413ab94c8d75ece08646
    - rid: 4444056937922035799
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 14135ef00796413ab94c8d75ece08646
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: This will be it from me. Good luck, scholar.
        addToLog: 1
        nextStepId: dad628b7f7bf41e9b7a1596b95f27b16
    - rid: 4444056937922035800
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: fb117d54478240578443525b9aff2b06
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Shinrai swings his cloak and vanishes. However, he is instantly replaced
          by a tall man with hair the color of moonlight. '
        addToLog: 1
        nextStepId: f8eb1f3629504b268e2be678576068b3
    - rid: 4444056937922035801
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 85de1a9956a444b9a584d2cb5d4a1683
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Greetings to you, curious soul. I am Kensui of the Temple of the Everveil.
          And I would like to learn more about you.Take a deep breath and let your
          spirit speak for you. '
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035803
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 99bf83e119a64b56a201b6be26916d31
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: How do you choose a spell you're going to cast?
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035804
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: ebd89ad7147846f782e8967ba1ab3933
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Very carefully and thoroughly. I like to think it through.
          nextStepId: 54954069b361444f963cc7c910ea602d
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Rather spontaneously. It comes naturally to me.
          nextStepId: 54954069b361444f963cc7c910ea602d
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035805
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 54954069b361444f963cc7c910ea602d
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kensui smiles at you and your heart immediately feels at peace.

'
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035806
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 383ca55610874eb0bcf806d387c13594
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: It is important that we know ourselves, precious soul, much like we
          try to understand our fellow scholars.
        addToLog: 1
        nextStepId: e8d4bd8230a24590918883b21e09fcf3
    - rid: 4444056937922035807
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: e8d4bd8230a24590918883b21e09fcf3
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: At a party with fellow magicians you like to...
        addToLog: 1
        nextStepId: a5eb1c49c6964ae98113e09b937a4360
    - rid: 4444056937922035809
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: a5eb1c49c6964ae98113e09b937a4360
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Talk to many people, including those I don't know yet.
          nextStepId: 05674824e3bc40258727216b3ae91379
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Interact with a few people I know well.
          nextStepId: 05674824e3bc40258727216b3ae91379
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035810
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 05674824e3bc40258727216b3ae91379
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: I see what you mean. And now, for the final question! Lumis, I might
          require your assistance.
        addToLog: 1
        nextStepId: a72de031dcc8483bb87a68cba769ced7
    - rid: 4444056937922035811
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: a72de031dcc8483bb87a68cba769ced7
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: On it, master!
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035812
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: fa8aa4b296644903b7e7be3c4d900fec
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "Kensui takes off his scarf, with Lumis grasping one end and Kensui
          the other, they gently cover you with it. \n"
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035813
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 884776f3b8ea47a988527b8795a49658
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: You catch Kensui's warm gaze one last time and suddenly realise you're
          drifting among the stars! Your mind feels crystal clear as you hear a familiar
          voice echo through this wonderful illusion.
        addToLog: 1
        nextStepId: eb993259dc5a4d29a9601579190a2c0b
    - rid: 4444056937922035814
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: eb993259dc5a4d29a9601579190a2c0b
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kensui''s scarf is back in his hands. He bows to you before he speaks
          again.

'
        addToLog: 1
        nextStepId: eea8eaf1ec1746de95066855053e255e
    - rid: 4444056937922035815
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: eea8eaf1ec1746de95066855053e255e
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Thank you for answering all of my questions. I hope to see you again
          in the near future! '
        addToLog: 1
        nextStepId: 94af26fdd7ed4df993998517b0959767
    - rid: 4444056937922035818
      type: {class: VNCommandStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 94af26fdd7ed4df993998517b0959767
        label: 
        disableSkip: 0
        stopAuto: 0
        command:
          rid: 4444056937922035820
        nextStepId: dcf102c99e6143f0b2d01be4382dac6a
    - rid: 4444056937922035820
      type: {class: VNHideCharacterCommand, ns: VN, asm: Assembly-CSharp}
      data:
        slot: 0
        fadeSeconds: 0.2
    - rid: 4444056937922035821
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: dcf102c99e6143f0b2d01be4382dac6a
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'A man in an amber uniform appears beside Kensui. He nods at you and
          Kensui, and Kensui smiles at him calmly before he vanishes into the fog.

'
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035822
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: e60187e035e94d3892823d931304cc77
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: Allow me to introduce Commander Kaitora of the Legion of Sentinels!
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035823
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 498bd0b34ff54631b8b87b1ddb0dba24
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Commander Kaitora steps forward. Tall and lean, he exudes strength
          and confidence.

'
        addToLog: 1
        nextStepId: 00883d5ea7494331b5e4fd2b6a58585d
    - rid: 4444056937922035824
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: ba8b1ded55914c51bc80209b35e64851
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: Good day. The Legion of Sentinels are the Academy's loyal servants
          and its primary line of defence. Let's see if you're one of us.That is,
          if you have what it takes.
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035825
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: a4340abda254473c8e077344bfc93b87
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: You're in charge of younger sentinels. It is harder for you to...
        addToLog: 1
        nextStepId: 0050a3bcbdf448d98369a61b9c636dd6
    - rid: 4444056937922035826
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 0050a3bcbdf448d98369a61b9c636dd6
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Identify with others.
          nextStepId: e7ef0681a54e4cc9af99a09a1816483c
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Make the most of what others can offer.
          nextStepId: e7ef0681a54e4cc9af99a09a1816483c
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035827
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: e7ef0681a54e4cc9af99a09a1816483c
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: Got it. Sentinels tend to team up to achieve maximum efficiency.
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035828
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 0a798fe315624c669226c7f449cc6f1f
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: 'In a new team you normally... '
        addToLog: 1
        nextStepId: 59c82d7f2e9942c790a55ea8509af016
    - rid: 4444056937922035829
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 59c82d7f2e9942c790a55ea8509af016
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Start the conversation yourself.
          nextStepId: f234fc4cc72a4b449f776953fbcbe2de
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Wait to be approached by others.
          nextStepId: f234fc4cc72a4b449f776953fbcbe2de
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035830
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: f234fc4cc72a4b449f776953fbcbe2de
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: Fair. Now to the final question. Lumis?
        addToLog: 1
        nextStepId: eb8493a942404a76ac7095bb538163db
    - rid: 4444056937922035831
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: eb8493a942404a76ac7095bb538163db
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Commander.
        addToLog: 1
        nextStepId: 194fbf0e63234024b8ee85525555c4b8
    - rid: 4444056937922035832
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 194fbf0e63234024b8ee85525555c4b8
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "You watch Lumis place a golden hourglass into Kaitora's hands. \n"
        addToLog: 1
        nextStepId: e1b6d0fee04a431ba30e8ac4236e2305
    - rid: 4444056937922035833
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: e1b6d0fee04a431ba30e8ac4236e2305
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Woah! It's heavy!
        addToLog: 1
        nextStepId: d470d3bdaf3945898814781cc5730b1b
    - rid: 4444056937922035834
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: d470d3bdaf3945898814781cc5730b1b
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: 'So is the weight of time. '
        addToLog: 1
        nextStepId: 7654eafc220645899d14a4b8f7778c72
    - rid: 4444056937922035835
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 7654eafc220645899d14a4b8f7778c72
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kaitora turns back to you.

'
        addToLog: 1
        nextStepId: 095ab6fd2b8744f78317443996562c3b
    - rid: 4444056937922035836
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 095ab6fd2b8744f78317443996562c3b
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: 'We use this hourglass to time our practices and to remind ourselves
          that nothing is eternal. '
        addToLog: 1
        nextStepId: de4167ae337d4a67bacf3a41614f016c
    - rid: 4444056937922035837
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: de4167ae337d4a67bacf3a41614f016c
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kaitora flips the hourglass over and the sand starts to fall from
          the top chamber.

'
        addToLog: 1
        nextStepId: a4e93e87e9f64e60a7798726589b802f
    - rid: 4444056937922035838
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: a4e93e87e9f64e60a7798726589b802f
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: Now, tell me what your perspective on time is.
        addToLog: 1
        nextStepId: d2d4cada830d41e59a7bfb57673d3f31
    - rid: 4444056937922035839
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: d2d4cada830d41e59a7bfb57673d3f31
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: When it comes to life events, one should...
        addToLog: 1
        nextStepId: a8587a9cd29c4f3abb8d16a894ec5c8c
    - rid: 4444056937922035844
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: a8587a9cd29c4f3abb8d16a894ec5c8c
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Try to choose and plan them carefully.
          nextStepId: f5ecd5ec7d264e1881a31df712822a64
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Let them happen randomly and by chance.
          nextStepId: f5ecd5ec7d264e1881a31df712822a64
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035845
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: f5ecd5ec7d264e1881a31df712822a64
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Suddenly, a warm breeze blows, wrapping you up in a whirlwind of golden
          petals.

'
        addToLog: 1
        nextStepId: de3e3dc58a8548c68278ef1ab8714a09
    - rid: 4444056937922035846
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: de3e3dc58a8548c68278ef1ab8714a09
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: This is a sign of luck! I'm sure of it.
        addToLog: 1
        nextStepId: 405f9ba8a7d24b629a9a7202a884f3dd
    - rid: 4444056937922035847
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: b38f426ce77044dca3f0f71c712b7d2f
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Master Hinato! You're already here?
        addToLog: 1
        nextStepId: 8cd1478921dc4cacbacdeb3dcb68b3d1
    - rid: 4444056937922035848
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 8cd1478921dc4cacbacdeb3dcb68b3d1
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: You're just in time. We have finished. Scholar, I wish you best of
          luck.
        addToLog: 1
        nextStepId: 0a97506085a34b51a7266b3cfa531bca
    - rid: 4444056937922035849
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 88be12c6de5e47028df7441c329cd688
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'A giant shield appears in the air, concealing Kaitora behind it. When
          the shield disappears, Kaitora is gone too. Hinato bows to you, a mischievous
          grin flickering on his lips.

'
        addToLog: 1
        nextStepId: da05628ea5b045a1b8abf1c3b33e6669
    - rid: 4444056937922035850
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: 44777667d1c649e5a41876e276d27a82
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 0
        sfxId: 
        text: Master Hinato of the Guild of the Flow at your service.
        addToLog: 1
        nextStepId: 10b704a2597c4868bcb180f4388f1e07
