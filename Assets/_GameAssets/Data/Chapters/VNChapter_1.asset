        nextStepId: chapter_1_line_r028_c03
    - rid: 9129764407459971359
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: chapter_1_line_r028_c03
        label: "R28 C3 Shinrai: I expect you to be extra cautiou\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: I expect you to be extra cautious, scholar. It is better to know your
