        nextStepId: chapter_1_line_r025_c03
    - rid: 9129764407459971356
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: chapter_1_line_r025_c03
        label: "R25 C3 Narrator: Shinrai remains visibly calm but\u2026"
