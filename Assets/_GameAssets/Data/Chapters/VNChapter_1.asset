    - rid: 9129764407459971357
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: chapter_1_line_r026_c03
        label: "R26 C3 You: Teacher Shinrai looks unusually \u2026"
