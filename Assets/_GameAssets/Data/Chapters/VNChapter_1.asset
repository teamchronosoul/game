    - rid: 9129764407459971358
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: chapter_1_line_r027_c03
        label: "R27 C3 Narrator: Shinrai looks you in the eyes. P\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: Shinrai looks you in the eyes. Perfectly composed as before.
