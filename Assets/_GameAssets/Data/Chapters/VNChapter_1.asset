    - rid: 9129764407459971352
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: chapter_1_line_r019_c03
        label: "R19 C3 Shinrai: Studying at Chronosoul is challe\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: Studying at Chronosoul is challenging in and of itself...
        addToLog: 1
        nextStepId: chapter_1_line_r020_c03
    - rid: 9129764407459971353
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: chapter_1_line_r020_c03
        label: "R20 C3 Shinrai: However, now that the academy ma\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: However, now that the academy may require fully-prepared battle mages
          at any moment, it is especially important that you work diligently and
          heed your mentors' guidance.
        addToLog: 1
        nextStepId: chapter_1_choice_r021_c03
