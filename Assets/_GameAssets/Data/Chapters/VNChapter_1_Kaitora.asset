        nextStepId: vnchapter_1_kaitora_line_r030_c03
    - rid: 9129764570494402791
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r030_c03
        label: "R30 C3 Kaitora: Chronosoul and the neighboring m\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 3
        showSpeakerName: 1
        sfxId: 
        text: Chronosoul and the neighboring magic-neutral towns and villages are
          no place for demons.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r031_c03
    - rid: 9129764570494402792
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r031_c03
        label: "R31 C3 Kaitora: They're clearly feeling a lot st\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 3
        showSpeakerName: 1
        sfxId: 
        text: They're clearly feeling a lot stronger if they had the guts to break
          the old agreements and try to provoke us like this.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r032_c03
    - rid: 9129764570494402793
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r032_c03
        label: "R32 C3 Narrative: Kaitora meets your gaze and imme\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Narrative
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Kaitora meets your gaze and immediately regains composure.
        addToLog: 1
