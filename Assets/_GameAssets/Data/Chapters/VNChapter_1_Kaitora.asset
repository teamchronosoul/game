      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r003_c03
        label: "R3 C3 Narrator: You step into a large field with\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You step into a large field with archery targets, training dummies,
          and other gear aimed at helping the students improve their fitness and
          combat skills.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r004_c03
    - rid: 9129764570494402774
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r004_c03
        label: "R4 C3 Narrator: Your mentor is wielding a sword,\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Your mentor is wielding a sword, instructing a group of sentinels.
          You can't hear what he's saying but you can see how smooth and precise
          his movements are.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r005_c03
    - rid: 9129764570494402775
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r005_c03
        label: "R5 C3 Narrator: He notices you, gives his sword \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: He notices you, gives his sword to one of the students and starts walking
          in your direction.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r006_c03
    - rid: 9129764570494402776
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r006_c03
        label: "R6 C3 Kaitora: Keep practicing. And pay attenti\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Keep practicing. And pay attention to your footwork.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r007_c03
    - rid: 9129764570494402777
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r007_c03
        label: "R7 C3 Narrator: Kaitora's students continue exer\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Kaitora's students continue exercising when he approaches you and greets
          you with a nod.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r008_c03
    - rid: 9129764570494402778
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r008_c03
        label: "R8 C3 Kaitora: Welcome to the Legion of Sentine\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 5
        showSpeakerName: 1
        sfxId: 
        text: Welcome to the Legion of Sentinels, scholar.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r009_c03
    - rid: 9129764570494402779
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r009_c03
        label: "R9 C3 Narrator: He points at the field behind hi\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
