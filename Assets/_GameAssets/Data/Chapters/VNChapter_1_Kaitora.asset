    - rid: 9129764570494403007
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r017_c05
        label: "R17 C5 Kaitora: Or maybe it's just that I like b\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Or maybe it's just that I like being out in the sun. It helps me think.
