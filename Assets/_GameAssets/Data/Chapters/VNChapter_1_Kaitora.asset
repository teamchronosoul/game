        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Kaitora looks thoughtful for a moment.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r014_c05
    - rid: 9129764570494403004
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r014_c05
        label: "R14 C5 Kaitora: I believe I wanted you to feel t\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 6
        showSpeakerName: 1
        sfxId: 
        text: I believe I wanted you to feel the spirit of the sentinels from day
          one.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r015_c05
    - rid: 9129764570494403005
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r015_c05
        label: "R15 C5 Kensui: There's nothing like honing your\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 5
        showSpeakerName: 1
        sfxId: 
        text: There's nothing like honing your combat skills alongside your fellow
          sentinels.
        addToLog: 1
        nextStepId: vnchapter_1_kaitora_line_r016_c05
    - rid: 9129764570494403006
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kaitora_line_r016_c05
        label: "R16 C5 Narrator: Kaitora meets your gaze as the w\u2026"
        disableSkip: 0
