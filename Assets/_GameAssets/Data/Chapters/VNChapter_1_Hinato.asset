    - rid: 9129764567614750762
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r011_c03
        label: "R11 C3 Hinato: Sorry, I'm a bit late. I had tro\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Sorry, I'm a bit late. I had trouble climbing up that old ladder outside
          the window.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r012_c03
    - rid: 9129764567614750763
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r012_c03
        label: "R12 C3 Narrator: Hinato clears his throat and sta\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Hinato clears his throat and starts speaking with exaggerated solemnity.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r013_c03
    - rid: 9129764567614750764
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r013_c03
        label: "R13 C3 Hinato: I am pleased to welcome you to t\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: I am pleased to welcome you to the Guild of the Flow, scholar. I hope
          you find your time with us productive and academically fulfilling.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r014_c03
    - rid: 9129764567614750765
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r014_c03
        label: "R14 C3 Narrator: Hinato bows to you, then lifts h\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Hinato bows to you, then lifts his head and gives you the cheekiest
          wink, all while still keeping a serious look on his face.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_choice_r015_c03
    - rid: 9129764567614750766
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
