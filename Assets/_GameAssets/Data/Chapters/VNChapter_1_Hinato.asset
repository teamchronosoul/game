    - rid: 9129764567614750768
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r022_c03
        label: "R22 C3 Hinato: I'll be honest with you, little \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: I'll be honest with you, little spark.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r023_c03
    - rid: 9129764567614750769
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r023_c03
        label: "R23 C3 Hinato: All I ever want my students to d\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: All I ever want my students to do is have a good time while exploring
          themselves and their magical abilities.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r024_c03
    - rid: 9129764567614750770
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r024_c03
        label: "R24 C3 Hinato: However, as your mentor, I must \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: However, as your mentor, I must warn you about the situation outside
          the academy and what might be heading our way.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r025_c03
    - rid: 9129764567614750771
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r025_c03
        label: 'R25 C3 Hinato: Do you see what I''m getting at?'
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Do you see what I'm getting at?
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r026_c03
    - rid: 9129764567614750772
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r026_c03
        label: "R26 C3 You: He must be talking about recent \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: You
        pose: 0
        emotion: 7
        showSpeakerName: 1
        sfxId: 
        text: He must be talking about recent rumors of demons lurking in a small
          town near the academy.
        addToLog: 1
        nextStepId: vnchapter_1_hinato_choice_r027_c03
    - rid: 9129764567614750773
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
