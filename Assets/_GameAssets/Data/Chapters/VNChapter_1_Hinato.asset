    - rid: 9129764567614750757
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r006_c03
        label: "R6 C3 You: Hmm. That's weird. Have I got th\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: You
        pose: 0
        emotion: 7
        showSpeakerName: 1
        sfxId: 
        text: Hmm. That's weird. Have I got the time wrong?
        addToLog: 1
        nextStepId: vnchapter_1_hinato_line_r007_c03
    - rid: 9129764567614750758
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r007_c03
        label: "R7 C3 Narrator: Suddenly you hear some noise com\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
