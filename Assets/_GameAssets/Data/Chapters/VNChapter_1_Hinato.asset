        nextStepId: vnchapter_1_hinato_choice_r030_c03
    - rid: 9129764567614750775
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_choice_r030_c03
        label: Choice R30 C3
        disableSkip: 0
        stopAuto: 0
        options:
        - text: If only these were rumors, little spark.
          nextStepId: vnchapter_1_hinato_line_r031_c03
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Adamant and fearless.Tell you what, I'm not surprised you got sorted
