      data:
        id: vnchapter_1_hinato_line_r010_c03
        label: "R10 C3 Hinato: Oh, look who's here! Hi there, l\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 4
        showSpeakerName: 1
        sfxId: 
        text: Oh, look who's here! Hi there, little spark!
