    - rid: 9129764567614750759
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_hinato_line_r008_c03
        label: "R8 C3 Hinato: Strike a light! I'd better fix t\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 3
        showSpeakerName: 1
        sfxId: 
        text: Strike a light! I'd better fix that blasted ladder before it kills
