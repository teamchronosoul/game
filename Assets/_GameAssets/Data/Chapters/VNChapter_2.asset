      data:
        id: vnchapter_2_line_r003_c03
        label: "R3 C3 Yuzuri: Come on! Why are you so slow? We\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Yuzuri
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: "Come on! Why are you so slow? We gotta get to Teacher Kaitora\u2019s
          practice!"
        addToLog: 1
        nextStepId: vnchapter_2_line_r004_c03
    - rid: 9129764703577833555
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r004_c03
        label: "R4 C3 Yuzuri: I love that he chose to take our\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Yuzuri
        pose: 0
        emotion: 1
        showSpeakerName: 1
        sfxId: 
        text: "I love that he chose to take our practice outside. Today\u2019s such
          a lovely weather!"
        addToLog: 1
        nextStepId: vnchapter_2_line_r005_c03
    - rid: 9129764703577833556
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r005_c03
        label: "R5 C3 Narrator: You look at Yuzuri, a silent que\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You look at Yuzuri, a silent question in your eyes.
        addToLog: 1
        nextStepId: vnchapter_2_line_r006_c03
    - rid: 9129764703577833557
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r006_c03
        label: "R6 C3 You: How is she suddenly so upbeat? D\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: You
        pose: 0
        emotion: 7
        showSpeakerName: 1
        sfxId: 
        text: How is she suddenly so upbeat? Does she not know what happened?
        addToLog: 1
        nextStepId: vnchapter_2_line_r007_c03
    - rid: 9129764703577833558
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r007_c03
        label: "R7 C3 You: There must me an explanation to \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: You
        pose: 0
        emotion: 7
        showSpeakerName: 1
        sfxId: 
        text: There must me an explanation to the visions I've been getting when
          I'm around Yuzuri.
        addToLog: 1
        nextStepId: vnchapter_2_line_r008_c03
    - rid: 9129764703577833559
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r008_c03
        label: "R8 C3 Yuzuri: You've stopped walking. Is every\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Yuzuri
        pose: 0
        emotion: 4
        showSpeakerName: 1
        sfxId: 
        text: You've stopped walking. Is everything alright?
        addToLog: 1
        nextStepId: vnchapter_2_choice_r009_c03
