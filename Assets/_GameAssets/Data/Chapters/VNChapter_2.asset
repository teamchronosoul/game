        nextStepId: vnchapter_2_line_r030_c03
    - rid: 9129764572344615142
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r030_c03
        label: "R30 C3 Kaitora: I need each of you to take a bow\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: I need each of you to take a bow and meet me at the targets when you're
          ready.
        addToLog: 1
        nextStepId: vnchapter_2_line_r031_c03
    - rid: 9129764572344615143
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r031_c03
        label: "R31 C3 Narrator: Kaitora turns around and starts \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: "Kaitora turns around and starts walking towards other students who\u2019ve
          only just arrived."
        addToLog: 1
        nextStepId: vnchapter_2_line_r032_c03
    - rid: 9129764572344615144
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r032_c03
        label: "R32 C3 Yuzuri: Using real weapons?! On the firs\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Yuzuri
        pose: 0
        emotion: 4
        showSpeakerName: 1
        sfxId: 
        text: Using real weapons?! On the first day of school? How cool is that?
        addToLog: 1
        nextStepId: vnchapter_2_line_r033_c03
    - rid: 9129764572344615145
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r033_c03
        label: "R33 C3 Yuzuri: Commander really doesn't mess ar\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Yuzuri
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Commander really doesn't mess around, does he!
        addToLog: 1
