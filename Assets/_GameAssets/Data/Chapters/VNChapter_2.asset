    - rid: 9129764572344615132
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r016_c03
        label: "R16 C3 Narrator: You turn around and see him walk\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You turn around and see him walking calmly towards you, the light summer
