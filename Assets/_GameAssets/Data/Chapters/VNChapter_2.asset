    - rid: 9129764572344615141
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r029_c03
        label: "R29 C3 Narrator: You give Yuzuri a look and she i\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You give Yuzuri a look and she imitates zipping her mouth shut.
