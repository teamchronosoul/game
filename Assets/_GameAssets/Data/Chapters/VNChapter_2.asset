    - rid: 9129764703577833565
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r019_c03
        label: "R19 C3 Narrator: He nods at you, his hand holding\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: He nods at you, his hand holding on to his cloak.
        addToLog: 1
        nextStepId: vnchapter_2_line_r020_c03
    - rid: 9129764703577833566
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r020_c03
        label: "R20 C3 Kaitora: No need for titles. Kaitora is g\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: No need for titles. Kaitora is good enough.
        addToLog: 1
        nextStepId: vnchapter_2_line_r021_c03
    - rid: 9129764703577833567
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r021_c03
        label: "R21 C3 Kaitora: You've come here early. This mea\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You've come here early. This means you have enough time to get ready.
          I approve of this.
        addToLog: 1
        nextStepId: vnchapter_2_line_r022_c03
    - rid: 9129764703577833568
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r022_c03
        label: "R22 C3 Narrator: This is when you notice he\u2019s hol\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: "This is when you notice he\u2019s holding a golden bow with some initials
          engraved into it."
        addToLog: 1
        nextStepId: vnchapter_2_choice_r023_c03
    - rid: 9129764703577833569
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_choice_r023_c03
        label: Choice R23 C3
        disableSkip: 0
