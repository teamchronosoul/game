    - rid: 9129764703577833570
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_2_line_r028_c03
        label: "R28 C3 Yuzuri: Woah, this raises so many questi\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Yuzuri
        pose: 0
