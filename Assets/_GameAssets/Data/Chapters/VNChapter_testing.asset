          rid: 4444056912327082058
        nextStepId: step_003
    - rid: 4444056912327082058
      type: {class: VNShowCharacterCommand, ns: VN, asm: Assembly-CSharp}
      data:
        characterId: Lumis
        slot: 1
        pose: 0
        emotion: 0
        crossfadeSeconds: 0.2
    - rid: 4444056912327082061
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_004
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: You're standing in the middle of the mystery forest, mustering up your
          courage. You're about to become a student at ChronoSoul, the legendary
          Magical Academy!
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082062
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_005
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "The wondrous creature in front of you speaks again, glowing with warm
          light. \n"
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082063
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_006
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: My name is Lumis. And I am here to ensure your test runs smoothly!
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082064
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_007
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Do you have any questions before we start?
        addToLog: 1
        nextStepId: step_008
    - rid: 4444056912327082065
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_008
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: "Tell me what's going to happen, step by step. \n"
          nextStepId: step_009
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Whatever comes up today, I'm ready.
          nextStepId: step_010
          kind: 0
          premiumPrice: 0
          effects:
          - type: 0
            key: 
            boolValue: 0
            intValue: 0
            stringValue: 
    - rid: 4444056912327082067
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_012
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 5
        sfxId: 
        text: 'I got you. You''re going to meet a mentor from each of the 4 faculties
          of the Magical Academy. '
        addToLog: 1
        nextStepId: step_013
    - rid: 4444056912327082068
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_014
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 5
        sfxId: 
        text: Oh, look! Here's the first mentor!
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082069
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_015
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: A tall, pale man with a piercing, cold gaze appears before you.
        addToLog: 1
        nextStepId: 
    - rid: 4444056912327082070
      type: {class: VNCommandStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_016
        label: 
        disableSkip: 0
        stopAuto: 0
        command:
          rid: 4444056912327082072
        nextStepId: step_018
    - rid: 4444056912327082072
      type: {class: VNShowCharacterCommand, ns: VN, asm: Assembly-CSharp}
      data:
        characterId: Shinrai
        slot: 0
        pose: 0
        emotion: 0
        crossfadeSeconds: 0.2
    - rid: 4444056912327082073
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_017
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Good day to you. I am Shinrai, Dean of the Order of Labyrinth. And
          I DO NOT enjoy small talk, so let us get straight to the point. '
        addToLog: 1
        nextStepId: step_019
    - rid: 4444056937922035779
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_019
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: What is your work routine like?
        addToLog: 1
        nextStepId: step_020
    - rid: 4444056937922035780
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_020
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: I prefer to have a schedule with clear deadlines.
          nextStepId: step_022
          kind: 0
          premiumPrice: 0
          effects: []
        - text: I like to work when I feel inspired
          nextStepId: step_021
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035782
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_023
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: 'I see. I have to warn you. Studying at the Academy is no easy endeavor.
          You must be prepared to apply your brilliant mind whenever it is required. '
        addToLog: 1
        nextStepId: step_024
    - rid: 4444056937922035784
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_025
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: How do you approach ordinary things?
        addToLog: 1
        nextStepId: step_026
    - rid: 4444056937922035785
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_026
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Relying on regular tried-and-true methods
          nextStepId: step_028
          kind: 0
          premiumPrice: 0
          effects: []
        - text: I like to do them my own way
          nextStepId: step_027
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035786
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_029
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: ' Is that so?'
        addToLog: 1
        nextStepId: step_030
    - rid: 4444056937922035787
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_030
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: There is a hint of interest in Shinrai's intense gaze.
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035788
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_031
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 5
        sfxId: 
        text: 'Well, let us proceed to a truly intriguing question. Lumis, please
          assist. '
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035789
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_032
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 5
        sfxId: 
        text: Gladly!
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035790
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_033
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "Shinrai raises his hand, conjuring a small sphere in his palm. Lumis
          then shines a ray of light on the sphere and a tiny eye appears within
          it. \n"
        addToLog: 1
        nextStepId: step_034
    - rid: 4444056937922035791
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_035
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: 'This is the eye of the Labyrinth. It sees one''s true intentions. '
        addToLog: 1
        nextStepId: step_036
    - rid: 4444056937922035792
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_036
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: Now tell me. Is it worse...
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035797
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_037
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: To be unjust.
          nextStepId: step_039
          kind: 0
          premiumPrice: 0
          effects: []
        - text: To have no mercy for others.
          nextStepId: step_038
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035798
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_040
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'The eye in Shinrai''s palm blinks and shrinks itself until it''s no
          longer there. Shinrai nods at you politely.

'
        addToLog: 1
        nextStepId: step_041
    - rid: 4444056937922035799
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_041
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: This will be it from me. Good luck, scholar.
        addToLog: 1
        nextStepId: step_042
    - rid: 4444056937922035800
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_043
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Shinrai swings his cloak and vanishes. However, he is instantly replaced
          by a tall man with hair the color of moonlight. '
        addToLog: 1
        nextStepId: step_044
    - rid: 4444056937922035801
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_045
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Greetings to you, curious soul. '
        addToLog: 1
        nextStepId: step_047
    - rid: 4444056937922035803
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_049
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: How do you choose a spell you're going to cast?
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035804
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_050
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Very carefully and thoroughly. I like to think it through.
          nextStepId: step_052
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Rather spontaneously. It comes naturally to me.
          nextStepId: step_051
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035805
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_053
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kensui smiles at you and your heart immediately feels at peace.

'
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035806
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_054
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 6
        sfxId: 
        text: It is important that we know ourselves, precious soul, much like we
          try to understand our fellow scholars.
        addToLog: 1
        nextStepId: step_055
    - rid: 4444056937922035807
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_055
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: At a party with fellow magicians you like to...
        addToLog: 1
        nextStepId: step_056
    - rid: 4444056937922035809
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_056
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Talk to many people, including those I don't know yet.
          nextStepId: step_058
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Interact with a few people I know well.
          nextStepId: step_057
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035810
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_059
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        sfxId: 
        text: I see what you mean. And now, for the final question! Lumis, I might
          require your assistance.
        addToLog: 1
        nextStepId: step_060
    - rid: 4444056937922035811
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_060
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 5
        sfxId: 
        text: On it, master!
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035812
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_061
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "Kensui takes off his scarf, with Lumis grasping one end and Kensui
          the other, they gently cover you with it. \n\n"
        addToLog: 1
        nextStepId: step_062
    - rid: 4444056937922035813
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_063
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: You catch Kensui's warm gaze one last time and suddenly realise you're
          drifting among the stars! Your mind feels crystal clear as you hear a familiar
          voice echo through this wonderful illusion.
        addToLog: 1
        nextStepId: step_065
    - rid: 4444056937922035814
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_064
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kensui''s scarf is back in his hands. He bows to you before he speaks
          again.

'
        addToLog: 1
        nextStepId: step_069
    - rid: 4444056937922035815
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_069
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 6
        sfxId: 
        text: 'Thank you for answering all of my questions. I hope to see you again
          in the near future! '
        addToLog: 1
        nextStepId: step_070
    - rid: 4444056937922035818
      type: {class: VNCommandStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_070
        label: 
        disableSkip: 0
        stopAuto: 0
        command:
          rid: 4444056937922035820
        nextStepId: step_071
    - rid: 4444056937922035820
      type: {class: VNHideCharacterCommand, ns: VN, asm: Assembly-CSharp}
      data:
        slot: 0
        fadeSeconds: 0.2
    - rid: 4444056937922035821
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_071
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "A man in a golden uniform appears beside Kensui. \n"
        addToLog: 1
        nextStepId: step_072
    - rid: 4444056937922035822
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_073
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Allow me to introduce Commander Kaitora of the Legion of Sentinels!
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035823
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_074
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Commander Kaitora steps forward. Tall and lean, he exudes strength
          and confidence.

'
        addToLog: 1
        nextStepId: step_075
    - rid: 4444056937922035824
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_076
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: Good day. The Legion of Sentinels are the Academy's loyal servants
          and its primary line of defence. Let's see if you're one of us.
        addToLog: 1
        nextStepId: step_078
    - rid: 4444056937922035825
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_079
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: You're in charge of younger sentinels. It is harder for you to...
        addToLog: 1
        nextStepId: step_080
    - rid: 4444056937922035826
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_080
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Identify with others.
          nextStepId: step_082
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Make the most of what others can offer.
          nextStepId: step_081
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035827
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_083
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: Got it. Sentinels tend to team up to achieve maximum efficiency.
        addToLog: 1
        nextStepId: 
    - rid: 4444056937922035828
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_084
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: 'In a new team you normally... '
        addToLog: 1
        nextStepId: step_085
    - rid: 4444056937922035829
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_085
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Start the conversation yourself.
          nextStepId: step_087
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Wait to be approached by others.
          nextStepId: step_086
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035830
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_088
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 6
        sfxId: 
        text: Fair. Now to the final question. Lumis?
        addToLog: 1
        nextStepId: step_089
    - rid: 4444056937922035831
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_089
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 5
        sfxId: 
        text: Commander.
        addToLog: 1
        nextStepId: step_090
    - rid: 4444056937922035832
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_090
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "You watch Lumis place a golden hourglass into Kaitora's hands. \n"
        addToLog: 1
        nextStepId: step_091
    - rid: 4444056937922035833
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_091
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 0
        sfxId: 
        text: Woah! It's heavy!
        addToLog: 1
        nextStepId: step_094
    - rid: 4444056937922035834
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_092
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: 'So is the weight of time. '
        addToLog: 1
        nextStepId: step_093
    - rid: 4444056937922035835
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_093
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kaitora turns back to you.

'
        addToLog: 1
        nextStepId: step_095
    - rid: 4444056937922035836
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_095
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: 'We use this hourglass to time our practices and to remind ourselves
          that nothing is eternal. '
        addToLog: 1
        nextStepId: step_096
    - rid: 4444056937922035837
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_096
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Kaitora flips the hourglass over and the sand starts to fall from
          the top chamber.

'
        addToLog: 1
        nextStepId: step_097
    - rid: 4444056937922035838
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_097
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 5
        sfxId: 
        text: Now, tell me what your perspective on time is.
        addToLog: 1
        nextStepId: step_098
    - rid: 4444056937922035839
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_098
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: When it comes to life events, one should...
        addToLog: 1
        nextStepId: step_099
    - rid: 4444056937922035844
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_099
        label: 
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Try to choose and plan them carefully.
          nextStepId: step_101
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Let them happen randomly and by chance.
          nextStepId: step_100
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 4444056937922035845
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_102
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: 'Suddenly, a warm breeze blows, wrapping you up in a whirlwind of golden
          petals.

'
        addToLog: 1
        nextStepId: step_103
    - rid: 4444056937922035846
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_103
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 1
        sfxId: 
        text: This is a sign of luck! I'm sure of it.
        addToLog: 1
        nextStepId: step_104
    - rid: 4444056937922035847
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_105
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Lumis
        pose: 0
        emotion: 5
        sfxId: 
        text: Master Hinato! You're already here?
        addToLog: 1
        nextStepId: step_106
    - rid: 4444056937922035848
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_106
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Kaitora
        pose: 0
        emotion: 0
        sfxId: 
        text: You're just in time. We have finished. Scholar, I wish you best of
          luck.
        addToLog: 1
        nextStepId: step_107
    - rid: 4444056937922035849
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_108
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        sfxId: 
        text: "A giant shield appears in the air, concealing Kaitora behind it. When
          the shield disappears, Kaitora is gone too. \n"
        addToLog: 1
        nextStepId: step_109
    - rid: 4444056937922035850
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_111
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Hinato
        pose: 0
        emotion: 6
        sfxId: 
        text: Master Hinato of the Guild of the Flow at your service.
        addToLog: 1
        nextStepId: step_113
    - rid: 4444056937922035867
      type: {class: VNCommandStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_044
