  references:
    version: 2
    RefIds:
    - rid: 9129764570494403504
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r003_c03
        label: "R3 C3 Narrator: You step into your mentor's offi\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You step into your mentor's office and instantly spot an old floor-to-ceiling
          bookcase packed with books in all the languages this world speaks.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r004_c03
    - rid: 9129764570494403505
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r004_c03
        label: "R4 C3 Narrator: Before you get a chance to study\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Before you get a chance to study it, Shinrai invites you to take a
          seat.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r005_c03
    - rid: 9129764570494403506
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r005_c03
        label: "R5 C3 Shinrai: Greetings, scholar. I am pleased\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Greetings, scholar. I am pleased to welcome you to the Order of Labyrinth.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r006_c03
    - rid: 9129764570494403507
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r006_c03
        label: "R6 C3 Shinrai: A faculty renowned for its think\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 6
        showSpeakerName: 1
        sfxId: 
        text: A faculty renowned for its thinkers and strategists, we take pride
          in our academic achievements and the foresight that we provide to the academy.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r007_c03
    - rid: 9129764570494403508
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r007_c03
        label: "R7 C3 Narrator: You look at your mentor. He is s\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You look at your mentor. He is serious and distant, but there's a hint
          of pride in his voice.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r008_c03
    - rid: 9129764570494403509
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r008_c03
        label: "R8 C3 You: No wonder. Shinrai puts a lot of\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: You
        pose: 0
        emotion: 7
        showSpeakerName: 1
        sfxId: 
        text: No wonder. Shinrai puts a lot of his time into making sure the faculty
          stays at the top of Chronosoul's academic ratings.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r009_c03
    - rid: 9129764570494403510
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r009_c03
        label: "R9 C3 Shinrai: Do you have any questions you wo\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Do you have any questions you would like to ask? Now is the perfect
          time to do so.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_choice_r010_c03
    - rid: 9129764570494403511
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_choice_r010_c03
        label: Choice R10 C3
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Ask about the faculty
          nextStepId: vnchapter_1_shinrai_line_r011_c04
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Ask about Shinrai
          nextStepId: vnchapter_1_shinrai_line_r011_c05
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 9129764570494403512
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r017_c03
        label: "R17 C3 Narrator: You nod mulling over Shinrai's w\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You nod mulling over Shinrai's words.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r018_c03
    - rid: 9129764570494403513
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r018_c03
        label: "R18 C3 Shinrai: Now that I have somewhat appease\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Now that I have somewhat appeased your curiosity, there is something
          else I wish to mention.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r019_c03
    - rid: 9129764570494403514
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r019_c03
        label: "R19 C3 Shinrai: Studying at Chronosoul is challe\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Studying at Chronosoul is challenging in and of itself...
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r020_c03
    - rid: 9129764570494403515
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r020_c03
        label: "R20 C3 Shinrai: However, now that the academy ma\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: However, now that the academy may require fully-prepared battle mages
          at any moment, it is especially important that you work diligently and
          heed your mentors' guidance.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_choice_r021_c03
    - rid: 9129764570494403516
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_choice_r021_c03
        label: Choice R21 C3
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Ask about recent rumors
          nextStepId: vnchapter_1_shinrai_line_r022_c04
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Reassure him
          nextStepId: vnchapter_1_shinrai_line_r022_c05
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 9129764570494403517
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r024_c03
        label: "R24 C3 Shinrai: The fact that demons dared to ap\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 3
        showSpeakerName: 1
        sfxId: 
        text: The fact that demons dared to appear on magic-neutral territories is
          a warning sign for us.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r025_c03
    - rid: 9129764570494403518
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r025_c03
        label: "R25 C3 Narrator: Shinrai remains visibly calm but\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Shinrai remains visibly calm but you can see him clenching his fists.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r026_c03
    - rid: 9129764570494403519
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r026_c03
        label: "R26 C3 You: Teacher Shinrai looks unusually \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: You
        pose: 0
        emotion: 7
        showSpeakerName: 1
        sfxId: 
        text: Teacher Shinrai looks unusually tense. There must be more to this!
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r027_c03
    - rid: 9129764570494403520
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r027_c03
        label: "R27 C3 Narrator: Shinrai looks you in the eyes. P\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Shinrai looks you in the eyes. Perfectly composed as before.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r028_c03
    - rid: 9129764570494403521
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r028_c03
        label: "R28 C3 Shinrai: I expect you to be extra cautiou\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: I expect you to be extra cautious, scholar. It is better to know your
          enemy from the start.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r029_c03
    - rid: 9129764570494403522
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r029_c03
        label: "R29 C3 Narrator: You nod at your mentor. Cautious\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You nod at your mentor. Cautious is something you can do.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r030_c03
    - rid: 9129764570494403523
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r030_c03
        label: "R30 C3 Shinrai: This will be it from me. I shall\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: This will be it from me. I shall see you in the class shortly.
        addToLog: 1
        nextStepId: 78ddf434238e4fa98567f1cf9db21fe7
    - rid: 9129764570494403524
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_shinrai_line_r032_c03
        label: "R32 C3 Narrator: You're crossing one of the acade\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You're crossing one of the academy's endless gardens on your way to
          your first class when you hear someone shout.
        addToLog: 1
        nextStepId: vnchapter_1_shinrai_line_r033_c03
    - rid: 9129764570494403525
