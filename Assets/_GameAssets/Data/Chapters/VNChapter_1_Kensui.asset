    RefIds:
    - rid: 9129764567614751725
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r003_c03
        label: "R3 C3 Narrator: You step into a peaceful sunlit \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You step into a peaceful sunlit garden where every little detail was
          purposefully arranged by someone's careful hand.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r004_c03
    - rid: 9129764567614751726
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r004_c03
        label: "R4 C3 Narrator: A silver scale standing on a roc\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: A silver scale standing on a rock grabs your attention. Within its
          pans you find small stones engraved with symbols that you've never seen
          before.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r005_c03
    - rid: 9129764567614751727
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r005_c03
        label: "R5 C3 Kensui: These symbols represent the elem\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: These symbols represent the elements of this world and beyond.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r006_c03
    - rid: 9129764567614751728
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r006_c03
        label: "R6 C3 Narrator: Your mentor is standing behind y\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Your mentor is standing behind you, his silver hair softly lit by the
          sun. He speaks to you once more, his voice a gentle springtime melody.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r007_c03
    - rid: 9129764567614751729
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r007_c03
        label: "R7 C3 Kensui: Welcome to the Temple of the Eve\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 6
        showSpeakerName: 1
        sfxId: 
        text: Welcome to the Temple of the Everveil, precious soul. I hope the academy
          and our community will soon become your new home.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r008_c03
    - rid: 9129764567614751730
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r008_c03
        label: "R8 C3 Kensui: I'd like you to know that if you\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 6
        showSpeakerName: 1
        sfxId: 
        text: I'd like you to know that if you encounter any difficulties, you are
          always welcome to seek my assistance.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_choice_r009_c03
    - rid: 9129764567614751731
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_choice_r009_c03
        label: Choice R9 C3
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Thank him for the warm welcome
          nextStepId: vnchapter_1_kensui_line_r010_c04
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Ask about the faculty
          nextStepId: vnchapter_1_kensui_line_r010_c05
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 9129764567614751732
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r016_c03
        label: "R16 C3 Narrator: Kensui points at the silver scal\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Kensui points at the silver scale that you were studying earlier.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r017_c03
    - rid: 9129764567614751733
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r017_c03
        label: "R17 C3 Kensui: I see you've taken an interest i\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: I see you've taken an interest in this old scale of mine.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r018_c03
    - rid: 9129764567614751734
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r018_c03
        label: "R18 C3 Kensui: I believe, it is important to we\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: I believe, it is important to weigh all the factors carefully before
          reaching a decision... especially given the complexities of the modern
          world.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r019_c03
    - rid: 9129764567614751735
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r019_c03
        label: "R19 C3 Narrator: Kensui says the last sentence mo\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Kensui says the last sentence more softly, almost as if speaking to
          himself.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r020_c03
    - rid: 9129764567614751736
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r020_c03
        label: "R20 C3 Narrator: Although he looks calm on the su\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Although he looks calm on the surface, you notice the corner of his
          mouth twitch a little.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r021_c03
    - rid: 9129764567614751737
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r021_c03
        label: "R21 C3 You: He must be talking about recent \u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: You
        pose: 0
        emotion: 7
        showSpeakerName: 1
        sfxId: 
        text: He must be talking about recent rumors of demons lurking in a small
          town near the academy.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_choice_r022_c03
    - rid: 9129764567614751738
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_choice_r022_c03
        label: Choice R22 C3
        disableSkip: 0
        stopAuto: 0
        options:
        - text: Ask about the rumors
          nextStepId: vnchapter_1_kensui_line_r023_c04
          kind: 0
          premiumPrice: 0
          effects: []
        - text: Reassure him
          nextStepId: vnchapter_1_kensui_line_r023_c05
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 9129764567614751739
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r024_c03
        label: 'R24 C3 Narrative: Kensui lets out a soft laugh.'
        disableSkip: 0
        stopAuto: 0
        speakerId: Narrative
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Kensui lets out a soft laugh.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_choice_r025_c03
    - rid: 9129764567614751740
      type: {class: VNChoiceStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_choice_r025_c03
        label: Choice R25 C3
        disableSkip: 0
        stopAuto: 0
        options:
        - text: I am indeed. You are very perceptive, dear soul.
          nextStepId: vnchapter_1_kensui_line_r026_c03
          kind: 0
          premiumPrice: 0
          effects: []
        - text: I like your attitude, dear soul! And yes, you are absolutely right.
            Source willing, we will handle everything in its own time.
          nextStepId: vnchapter_1_kensui_line_r026_c03
          kind: 0
          premiumPrice: 0
          effects: []
    - rid: 9129764567614751741
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r026_c03
        label: 'R26 C3 Narrator: Kensui looks thoughtful.'
        disableSkip: 0
        stopAuto: 0
        speakerId: 
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: Kensui looks thoughtful.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r027_c03
    - rid: 9129764567614751742
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r027_c03
        label: "R27 C3 Kensui: For the first time in hundreds o\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: For the first time in hundreds of years, demons openly appeared on
          magic-neutral territories.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r028_c03
    - rid: 9129764567614751743
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r028_c03
        label: "R28 C3 Kensui: There was an energy shift in the\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: There was an energy shift in the Tear. I'd like you to be aware of
          that.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r029_c03
    - rid: 9129764570494402560
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r029_c03
        label: "R29 C3 Kensui: I would also like you to be care\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: I would also like you to be careful and let me or other mentors know
          if you notice anything suspicious.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r030_c03
    - rid: 9129764570494402561
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r030_c03
        label: "R30 C3 Narrative: You nod. Kensui smiles at you bu\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Narrative
        pose: 0
        emotion: 0
        showSpeakerName: 1
        sfxId: 
        text: You nod. Kensui smiles at you but his smile doesn't quite reach his
          eyes.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r031_c03
    - rid: 9129764570494402562
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r031_c03
        label: "R31 C3 Kensui: I wish I didn't have to tell you\u2026"
        disableSkip: 0
        stopAuto: 0
        speakerId: Kensui
        pose: 0
        emotion: 6
        showSpeakerName: 1
        sfxId: 
        text: I wish I didn't have to tell you all this on your first day at the
          academy, but such is our Fate.
        addToLog: 1
        nextStepId: vnchapter_1_kensui_line_r032_c03
    - rid: 9129764570494402563
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: vnchapter_1_kensui_line_r032_c03
        label: "R32 C3 Kensui: And here, at Temple of the Everv\u2026"
