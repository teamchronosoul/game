    - rid: 4444056890768883787
      type: {class: VNLineStep, ns: VN, asm: Assembly-CSharp}
      data:
        id: step_017
        label: 
        disableSkip: 0
        stopAuto: 0
        speakerId: Shinrai
        pose: 0
        emotion: 0
        sfxId: 
        text: Now that I have somewhat appeased your curiosity, there is something
          else I wish to mention.
        addToLog: 1
        nextStepId: 
