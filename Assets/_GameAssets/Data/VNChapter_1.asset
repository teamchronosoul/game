      type: {class: VNSetBackgroundCommand, ns: VN, asm: Assembly-CSharp}
      data:
        backgroundId: 1
        crossfadeSeconds: 0.25
    - rid: 4444056884916519069
      type: {class: VNShowCharacterCommand, ns: VN, asm: Assembly-CSharp}
